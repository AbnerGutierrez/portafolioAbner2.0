---
// components/Experience.astro
const trabajos = [
  {
    icono: "🟦",
    proyecto: "Resepción y seguimiento de aspirantes",
    empresa: "Comisión Federal de Electricidad",
    anio: "2024",
    herramientas: [
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/php/php-plain.svg",
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg",
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg",
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg",
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg",
    ],
  },
  {
    icono: "🟦",
    proyecto: "Sistema de correspondencia",
    empresa: "Universidad autonoma del estado de Morelos",
    anio: "2025",
    herramientas: [
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/laravel/laravel-original.svg",
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg",
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bootstrap/bootstrap-original.svg",
    ],
  },
  {
    icono: "🟦",
    proyecto: "Programa operativo anual",
    empresa: "Universidad autonoma del estado de Morelos",
    anio: "2025",
    herramientas: [
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/laravel/laravel-original.svg",
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg",
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bootstrap/bootstrap-original.svg",
    ],
  },
  {
    icono: "🟦",
    proyecto: "Ventanilla eléctronica",
    empresa: "Universidad autonoma del estado de Morelos",
    anio: "2026",
    herramientas: [
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/laravel/laravel-original.svg",
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg",
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bootstrap/bootstrap-original.svg",
    ],
  },
];

const personales = [
  {
    titulo: "lunadev.mx",
    herramientas: [
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/laravel/laravel-original.svg",
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg",
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg",
      "https://cdn.simpleicons.org/tailwindcss",
    ],
  },
   {
    titulo: "Sistema de libros",
    herramientas: [
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/django/django-plain.svg",
      "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg",
      "https://cdn.simpleicons.org/tailwindcss",
    ],
  },
];
---

<section class="section-wrap exp-section" id={"exp"}>
  <div class="exp-glow-center"></div>

  <div class="section-inner">
    <div class="exp-header">
      <div class="exp-icon">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect x="2" y="7" width="20" height="14" rx="2"></rect><path
            d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"></path></svg
        >
      </div>
      <h2 class="section-title" style="text-align:center">
        Experiencia laboral
      </h2>
      <p class="section-subtitle" style="text-align:center; margin:0 auto">
        Mi trayectoria profesional y proyectos
      </p>
    </div>

    <div class="exp-cols">
      <!-- Columna: Trabajo -->
      <div>
        <div class="exp-col-label">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
            ></path></svg
          >
          Trabajo
        </div>

        {
          trabajos.map((trabajo, index) => (
            <div class="exp-card">
              <div class="exp-card-icon">{trabajo.icono}</div>
              <div class="exp-card-body">
                <p class="exp-card-title">{trabajo.proyecto} </p>
                <p class="exp-card-company">{trabajo.empresa}</p>
                <div class="flex gap-2 justify-between">
                  <span class="exp-badge">{trabajo.anio}</span>
                  <div class="flex gap-2">
                    {trabajo.herramientas.map((tool, i) => (
                      <span>
                        <img
                          src={tool}
                          alt={tool}
                          width="16"
                          height="16"
                          onerror="this.style.display='none'"
                        />
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))
        }

        <!-- Agrega más cards aquí -->
      </div>

      <!-- Columna: Proyectos -->
      <div>
        <div class="exp-col-label">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M12 2L2 7l10 5 10-5-10-5M2 17l10 5 10-5M2 12l10 5 10-5"
            ></path></svg
          >
          Proyectos personales
        </div>

        {
          personales.map((item, index) => (
            <div class="exp-card">
              <div class="exp-card-icon">🌐</div>
              <div class="exp-card-body">
                <p class="exp-card-title">{item.titulo}</p>
                <p class="exp-card-company">Web</p>
                <div class="flex gap-2 justify-between">
                  <span class="exp-badge">2026</span>
                  <div class="flex gap-2">
                    {item.herramientas.map((tool, i) => (
                      <span>
                        <img
                          src={tool}
                          alt={tool}
                          width="16"
                          height="16"
                          onerror="this.style.display='none'"
                        />
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))
        }

        <!-- Agrega más cards aquí -->

        <div class="exp-footer">
          <span class="footer-dot"></span>
          Siempre aprendiendo y creciendo
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .exp-section {
    background: var(--color-bg);
  }

  .exp-glow-center {
    position: absolute;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(79, 107, 255, 0.1) 0%,
      transparent 65%
    );
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .exp-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .exp-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(99, 130, 255, 0.3);
    background: rgba(99, 130, 255, 0.08);
    margin-bottom: 1rem;
    color: var(--color-accent);
  }

  .exp-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .exp-col-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 0.5px solid rgba(122, 138, 181, 0.15);
  }
  .exp-col-label svg {
    color: var(--color-accent);
  }

  .exp-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: rgba(255, 255, 255, 0.03);
    border: 0.5px solid rgba(99, 130, 255, 0.15);
    border-radius: 10px;
    padding: 1rem;
    margin-bottom: 0.75rem;
    transition:
      border-color 0.2s,
      background 0.2s;
    cursor: default;
  }
  .exp-card:hover {
    border-color: rgba(99, 130, 255, 0.35);
    background: rgba(99, 130, 255, 0.06);
  }

  .exp-card-icon {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: rgba(99, 130, 255, 0.12);
    border: 0.5px solid rgba(99, 130, 255, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
  }

  .exp-card-body {
    flex: 1;
  }

  .exp-card-title {
    font-size: 0.85rem;
    font-weight: 500;
    color: #d0d8f5;
    margin: 0 0 2px;
    line-height: 1.3;
  }

  .exp-card-company {
    font-size: 0.75rem;
    color: #5a6a96;
    margin: 0 0 6px;
  }

  .exp-badge {
    display: inline-flex;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    background: rgba(99, 130, 255, 0.1);
    border: 0.5px solid rgba(99, 130, 255, 0.25);
    padding: 2px 8px;
    border-radius: 100px;
  }

  .exp-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 2rem;
    font-size: 0.75rem;
    color: #3a4a70;
  }

  .footer-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }

  @media (max-width: 580px) {
    .exp-cols {
      grid-template-columns: 1fr;
    }
  }
</style>
