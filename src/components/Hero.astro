---

---

<div id="container">
  <div>
    <!---Hero section-->
    <section class="hero-wrap">
      <div class="hero-grid-bg"></div>
      <div class="hero-glow"></div>
      <div class="hero-glow-2"></div>

      <div class="hero-inner">
        <!-- Texto -->
        <div class="hero-text">
          <div class="hero-badge">
            <span class="badge-dot"></span>
            Disponible para contratación
          </div>

          <h1 class="hero-name">
            Hola, soy<br /><p>Abner.</p>
          </h1>

          <p class="hero-role">Desarrollador Fullstack</p>

          <p class="hero-desc">
            Desarrollo aplicaciones web sólidas, enfocadas en escalabilidad y
            trabajo en equipo.
          </p>

          <div class="hero-actions">
            <a href="#exp" class="btn-primary"> 👁 Ver trabajo </a>
            <a href="/CVABNERGUTIERREZ.pdf" target="_blank" class="btn-ghost">
              ↓ Descargar CV
            </a>
          </div>
        </div>

        <!-- Imagen + stats -->
        <div class="hero-img-col">
          <div class="avatar-frame">
            <div class="avatar-ring"></div>
            <img
              class="avatar-img"
              src="https://img.freepik.com/vector-premium/imagen-perfil-avatar-hombre-aislada-fondo-imagen-profil-avatar-hombre_1293239-4861.jpg?semt=ais_hybrid&w=740&q=80"
              alt="Foto de perfil de Abner"
            />
          </div>

          <div class="hero-stats">
            <div class="stat">
              <div class="stat-num">2+</div>
              <div class="stat-label">Años exp.</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <div class="stat-num">24</div>
              <div class="stat-label">Edad</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <div class="stat-num">🎓</div>
              <div class="stat-label">Titulado</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>

<style>
  .hero-wrap {
    min-height: 100vh;
    background: #0a0f1e;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    position: relative;
    overflow: hidden;
    font-family: "DM Sans", sans-serif;
  }

  .hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(99, 130, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99, 130, 255, 0.06) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  .hero-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(79, 107, 255, 0.12) 0%,
      transparent 70%
    );
    top: -100px;
    right: -100px;
    pointer-events: none;
  }

  .hero-glow-2 {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(129, 210, 255, 0.08) 0%,
      transparent 70%
    );
    bottom: -80px;
    left: 0;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
    max-width: 900px;
    width: 100%;
  }

  .hero-text {
    animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(99, 130, 255, 0.12);
    border: 0.5px solid rgba(99, 130, 255, 0.35);
    color: #a0b4ff;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 1.75rem;
    animation: fadeUp 0.6s 0.1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: #6382ff;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }

  .hero-name {
    /* font-family: "DM Serif Display", serif; */
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 400;
    color: #f0f2ff;
    line-height: 1.05;
    margin: 0 0 0.5rem;
    animation: fadeUp 0.7s 0.15s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-name p {
    /* font-style: italic; */
    color: #6382ff;
  }

  .hero-role {
    font-size: 1.05rem;
    font-weight: 300;
    color: #7a8ab5;
    letter-spacing: 0.04em;
    margin: 0 0 2.25rem;
    animation: fadeUp 0.7s 0.22s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-desc {
    font-size: 0.95rem;
    line-height: 1.75;
    color: #5a6a96;
    max-width: 400px;
    margin: 0 0 2.5rem;
    animation: fadeUp 0.7s 0.28s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    animation: fadeUp 0.7s 0.35s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #4f6bff;
    color: #fff;
    font-family: "DM Sans", sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 12px 24px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition:
      background 0.2s,
      transform 0.15s;
    text-decoration: none;
  }
  .btn-primary:hover {
    background: #3a56f0;
    transform: translateY(-1px);
  }
  .btn-primary:active {
    transform: scale(0.98);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: #7a8ab5;
    font-family: "DM Sans", sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    padding: 12px 24px;
    border: 0.5px solid rgba(122, 138, 181, 0.35);
    border-radius: 8px;
    cursor: pointer;
    transition:
      border-color 0.2s,
      color 0.2s,
      transform 0.15s;
    text-decoration: none;
  }
  .btn-ghost:hover {
    border-color: rgba(122, 138, 181, 0.7);
    color: #b0bcd8;
    transform: translateY(-1px);
  }
  .btn-ghost:active {
    transform: scale(0.98);
  }

  .hero-img-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    animation: fadeIn 1s 0.3s both;
  }

  .avatar-frame {
    position: relative;
    width: 220px;
    height: 220px;
    flex-shrink: 0;
  }

  .avatar-ring {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1px solid rgba(99, 130, 255, 0.25);
    animation: spin 12s linear infinite;
  }

  .avatar-ring::after {
    content: "";
    position: absolute;
    width: 8px;
    height: 8px;
    background: #6382ff;
    border-radius: 50%;
    top: -4px;
    left: 50%;
    transform: translateX(-50%);
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .avatar-img {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(99, 130, 255, 0.2);
    display: block;
  }

  .hero-stats {
    display: flex;
    gap: 1.5rem;
  }

  .stat {
    text-align: center;
  }

  .stat-num {
    font-family: "DM Serif Display", serif;
    font-size: 1.6rem;
    color: #f0f2ff;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #4a5a85;
    margin-top: 4px;
  }

  .stat-divider {
    width: 0.5px;
    background: rgba(122, 138, 181, 0.2);
    align-self: stretch;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(22px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (max-width: 620px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }
    .hero-img-col {
      order: -1;
    }
    .avatar-frame {
      width: 160px;
      height: 160px;
    }
    .avatar-img {
      width: 160px;
      height: 160px;
    }
    .hero-desc {
      margin-left: auto;
      margin-right: auto;
    }
    .hero-actions {
      justify-content: center;
    }
    .hero-badge {
      justify-content: center;
    }
  }
</style>
