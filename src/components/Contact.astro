---
// components/Contact.astro
---

<section class="section-wrap contact-section">
  <div class="ct-glow"></div>

  <div class="ct-inner">
    <div class="ct-left">
      <h2 class="section-title">
        Abierto a nuevas <span class="accent">oportunidades</span>
      </h2>
      <p class="section-subtitle">
        Busco unirme a un equipo donde pueda aportar y crecer.<br />
      </p>

      <div class="ct-badges">
        <span class="ct-badge">Tiempo completo</span>
        <span class="ct-badge">Remoto / Híbrido</span>
        <span class="ct-badge">Disponible</span>
      </div>
    </div>

    <div class="ct-cards">
      <a class="ct-card" href="mailto:abneremanuelga@gmail.com">
        <div class="ct-card-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </div>
        <div class="ct-card-body">
          <p class="ct-card-type">Correo profesional</p>
          <p class="ct-card-value">abneremanuelga@gmail.com</p>
        </div>
        <svg
          class="ct-arrow"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>

      <a
        class="ct-card"
        href="https://wa.me/527341330970"
        target="_blank"
        rel="noopener"
      >
        <div class="ct-card-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
            ></path>
          </svg>
        </div>
        <div class="ct-card-body">
          <p class="ct-card-type">WhatsApp</p>
          <p class="ct-card-value">+52 734 133 09 70</p>
        </div>
        <svg
          class="ct-arrow"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>

      <a class="ct-card" href="/CVABNERGUTIERREZ.pdf" target="_blank">
        <div class="ct-card-icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
            ></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="12" y1="18" x2="12" y2="12"></line>
            <line x1="9" y1="15" x2="15" y2="15"></line>
          </svg>
        </div>
        <div class="ct-card-body">
          <p class="ct-card-type">Currículum</p>
          <p class="ct-card-value">Descargar CV</p>
        </div>
        <svg
          class="ct-arrow"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>

  <div class="ct-footer">
    <span class="ct-footer-dot"></span>
    Disponible para entrevistas
  </div>
</section>

<style>
  .contact-section {
    background: var(--color-bg);
  }

  .ct-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(79, 107, 255, 0.09) 0%,
      transparent 70%
    );
    bottom: -150px;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .ct-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .accent {
    color: var(--color-accent);
  }

  /* Badges de disponibilidad */
  .ct-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .ct-badge {
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    border: 0.5px solid rgba(99, 130, 255, 0.3);
    background: rgba(99, 130, 255, 0.07);
    color: #8aa0e8;
  }

  .ct-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ct-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    border: 0.5px solid rgba(99, 130, 255, 0.15);
    background: rgba(255, 255, 255, 0.025);
    text-decoration: none;
    transition: all 0.2s;
  }
  .ct-card:hover {
    border-color: rgba(99, 130, 255, 0.4);
    background: rgba(99, 130, 255, 0.07);
    transform: translateX(4px);
  }

  .ct-card-icon {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    border-radius: 10px;
    background: rgba(99, 130, 255, 0.1);
    border: 0.5px solid rgba(99, 130, 255, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
  }

  .ct-card-body {
    flex: 1;
    min-width: 0;
  }

  .ct-card-type {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #3a4a70;
    margin: 0 0 3px;
  }

  .ct-card-value {
    font-size: 0.95rem;
    color: #c0ccff;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ct-arrow {
    color: #3a4a70;
    flex-shrink: 0;
    transition:
      color 0.2s,
      transform 0.2s;
  }
  .ct-card:hover .ct-arrow {
    color: var(--color-accent);
    transform: translateX(3px);
  }

  .ct-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 0.5px solid rgba(122, 138, 181, 0.12);
    font-size: 0.75rem;
    color: #2a3a60;
  }

  .ct-footer-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }

  @media (max-width: 580px) {
    .ct-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
